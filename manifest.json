{
  "manifest_version": 3,
  "name": "VG Cookie Blocker",
  "version": "1.1",
  "description": "Removes Sourcepoint cookie consent popups and scroll locks",
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "css": ["block.css"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": ["*://*/*"]
}
